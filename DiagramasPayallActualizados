        <mxCell id="-MozXckfxEfHFRJWzKAZ-51" value="&lt;font style=&quot;font-size: 11px&quot;&gt;&lt;b&gt;5.&amp;nbsp;&lt;/b&gt;&lt;b&gt;La operadora Movilnet envía una respuesta como mensaje ISO8583 al Q2-Payall-Movilnet-Lite con el resultado de la recarga.&lt;/b&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;br&gt;Datos a enviar:&lt;br&gt;&lt;/font&gt;0 = 2010&lt;br&gt;3 = Codigo de procesamiento&lt;br&gt;11 = Numero de traza asignado por el emisor de la transaccion&lt;br&gt;12 = Hora local de la recepcion de la transaccion&lt;br&gt;13 = Fecha en la que se envia la transaccion&lt;br&gt;32 = Adquiriente que recibe la transaccion&lt;br&gt;33 = Bin del originador de la transaccion&lt;br&gt;41 = ID de la oficina y terminal bancario donde se realiza la transaccion&lt;br&gt;62 = Uso privado&lt;br&gt;		&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.1 = Codigo de modalidad&lt;br&gt;		&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.2 = Filler&lt;br&gt;		&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.3 = Codigo autorizador&lt;br&gt;		&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.4 = Codigo de respuesta&lt;br&gt;		&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.5 = Numero de referencia&lt;br&gt;		&lt;span style=&quot;background-color: rgb(255 , 255 , 51)&quot;&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.6 = Mensaje respuesta&amp;nbsp;(En el simulador se manda vacio)&lt;br&gt;&lt;span&gt;	&lt;/span&gt;&lt;span&gt;	&lt;/span&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.7 = Secuencia&amp;nbsp;(En el simulador se manda vacio)&lt;br&gt;&lt;span&gt;	&lt;/span&gt;&lt;span&gt;	&lt;/span&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.8 = Numero de lote&amp;nbsp;(En el simulador se manda vacio)&lt;/span&gt;&lt;br&gt;		&lt;span style=&quot;background-color: rgb(255 , 255 , 51)&quot;&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.9 = Telefono (En el simulador se manda vacio)&lt;br&gt;&lt;span&gt;	&lt;/span&gt;&lt;span&gt;	&lt;/span&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.10 = Fecha factura (En el simulador se manda vacio)&lt;/span&gt;&lt;br&gt;	&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.11 = Filler&lt;br&gt;	&lt;span style=&quot;background-color: rgb(255 , 255 , 51)&quot;&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.12 = Monto de pago (En el simulador se manda vacio)&lt;br&gt;&lt;/span&gt;	&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.13 = Filler&lt;br&gt;	&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.14 = Filler&lt;br&gt;	&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.15 = Numero de autorizacion" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;spacingTop=-6;fillColor=#fff2cc;strokeColor=#d6b656;" parent="_dlSYpshmapQyUOBsswE-1" vertex="1">

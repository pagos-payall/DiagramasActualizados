l (web) (INCONSISTENTE)&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.5 = Codigo de producto&lt;br&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.6 = Cedula cliente&lt;br&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.11 = Pin de seguridad&lt;br&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.12 = Codigo de seguridad&lt;br&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;62.13 = Codigo unico de cliente&lt;br&gt;121 = Codigo de operador de taquilla&lt;br&gt;124 = Numero de lote, de secuencia de lote y de turno&lt;br&gt;125 = Codigo numerico o siglas asociadas a la entidad&lt;br&gt;126 = Data de pre-autorizacion&lt;br&gt;&lt;span style=&quot;white-space: pre&quot;&gt;	&lt;/span&gt;" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;spacingTop=-6;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="_dlSYpshmapQyUOBsswE-1">
